      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum(rate(cognitive_http_latency_seconds_bucket[$__rate_interval])) by (endpoint, le))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum(rate(cognitive_http_latency_seconds_bucket[$__rate_interval])) by (endpoint, le))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum(rate(cognitive_http_latency_seconds_bucket[$__rate_interval])) by (endpoint, le))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "C"
        }
      ],
      "title": "HTTP Latency (p50/p95/p99)",
      "type": "timeseries"
    },
