# Cognitive Orchestrator env — copy to /etc/cognitive-orchestrator.env (chmod 600), fill values.
# NOT committed with real values. The launch wrapper auto-corrects host= in ORCH_DB_DSN
# to the live postgres docker IP, so the host part below is just a fallback.
ORCH_PORT=9099
ORCH_DB_DSN=host=172.18.0.X port=5432 dbname=cognitive_core user=cognitive password=CHANGE_ME
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
COGCORE_BASE=http://127.0.0.1:8000
COGCORE_INTERNAL=https://mcp.me-ai.ru
ORCH_SIGN_KEY=
ORCH_KEY=
AGENT_KEY_LAPTOP=
AGENT_KEY_ORCH=
ORCH_OWNER_CODE=
ORCH_EXEC_TIMEOUT_S=60
ORCH_WAKE_WAIT_S=5
COGCORE_SECRETS_MASTER_KEY=
