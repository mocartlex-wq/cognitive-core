# Cognitive Core — environment template.
#
# Copy to `.env` and fill REQUIRED slots. `make init` does it for you with
# auto-generated random secrets.
#
# Sections:
#   1. Required secrets       — must set, no safe default
#   2. Storage                — Postgres / Redis / MinIO connection
#   3. LLM providers          — DeepSeek primary, OpenAI optional fallback
#   4. Agents & rooms         — auth keys, runtime knobs
#   5. Curator & cycles       — memory consolidation tuning
#   6. Optional features      — local LLM (Ollama), GPU embeddings
# ─────────────────────────────────────────────────────────────────────

# ── 1. Required secrets ───────────────────────────────────────────────
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
S3_ACCESS_KEY=CHANGE_ME_minio_access_key
S3_SECRET_KEY=CHANGE_ME_minio_secret_key

# DeepSeek API (required for agent runtime + KG extraction + proxy answers).
# Get key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ── 2. Storage ────────────────────────────────────────────────────────
POSTGRES_DB=cognitive_core
POSTGRES_USER=cognitive
S3_BUCKET=l4-snapshots
S3_SECURE=false

# ── 3. LLM providers ──────────────────────────────────────────────────
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DAILY_ANALYZER=deepseek-chat
LLM_WEEKLY_CONSOLIDATOR=deepseek-chat
LLM_CURATOR_FILTER=deepseek-chat
LLM_CURATOR_QUALITY=deepseek-chat
LLM_CURATOR_AUDIT=deepseek-chat
LLM_CURATOR_ARBITRATION=deepseek-chat
LLM_EMBEDDING=deepseek-embedding

# Optional fallback (OpenAI). Leave blank to skip.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
LLM_FALLBACK=gpt-4o-mini

# ── 4. Agents & rooms ─────────────────────────────────────────────────
# Per-agent API keys (JSON: {"agent_id":"key", ...}).
# Generate keys with: openssl rand -hex 16
AGENT_API_KEYS={"alice":"key-alice-CHANGE","bob":"key-bob-CHANGE"}

# Rooms behaviour
PROXY_FALLBACK_AFTER=5     # seconds to wait for real agent before DeepSeek proxy
ROOMS_PORT=9098

# Public ports (override if conflicts on host)
API_PORT=9001

# Limits & safety
MAX_PAYLOAD_SIZE=262144
RATE_LIMIT_PER_AGENT=100
MAX_PAYLOAD_DEPTH=10
MAX_PAYLOAD_KEYS=500

# ── 5. Curator & cycles ───────────────────────────────────────────────
CURATOR_TEMPERATURE=0.1
MIN_EVENTS_FOR_DAILY=3
MIN_CONFIDENCE_FOR_L3=0.6
MIN_L2_REPETITIONS_FOR_L3=2
L4_FULL_SNAPSHOT_INTERVAL_WEEKS=4
L4_MIN_CHANGE_PERCENT=5
L3_STALENESS_DAYS=90
TOOL_UNUSED_DAYS=60

RETENTION_DAYS=14
DAILY_HOURS=24
WEEKLY_DAYS=7

# ── 6. Optional features ──────────────────────────────────────────────
# Local LLM via Ollama (skip if not using GPU box). Uncomment if needed.
LOCAL_AI_ENABLED=false
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_CURATOR_MODEL=qwen3:14b
# OLLAMA_FAST_MODEL=llama4:8b

# GPU acceleration for embeddings (requires Dockerfile.gpu)
EMBEDDING_USE_GPU=false

# A/B testing for curator models (0 = off)
LLM_AB_TRAFFIC_PERCENT=0

# Docker image override (use local build, ghcr.io tag, or pinned version).
# Default: ghcr.io/cognitive-core/api:latest
# IMAGE_API=cognitive-core-api:dev
