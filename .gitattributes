# Cognitive Core — line endings policy
# Сервер на Linux, разработка на Windows. Shell-скрипты должны быть LF
# иначе на Linux ломается shebang (`#!/usr/bin/env bash\r`).

*.sh        text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.conf      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
Dockerfile* text eol=lf
