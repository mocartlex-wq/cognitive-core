# Cognitive Core production .env TEMPLATE.
# DO NOT use these values in production — they are placeholders!
# Generate real secrets via: bash scripts/gen-secrets.sh > .env

# === STORAGES ===
DATABASE_URL=postgresql://cognitive:CHANGE_ME_TO_STRONG_PASSWORD@postgres:5432/cognitive_core
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

REDIS_URL=redis://redis:6379

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_STRING
S3_BUCKET=l4-snapshots
S3_SECURE=false

# === LLM ===
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=sk-YOUR-DEEPSEEK-KEY-HERE
LLM_DAILY_ANALYZER=deepseek-chat
LLM_WEEKLY_CONSOLIDATOR=deepseek-chat
LLM_CURATOR_FILTER=deepseek-chat
LLM_CURATOR_QUALITY=deepseek-chat
LLM_CURATOR_AUDIT=deepseek-chat
LLM_CURATOR_ARBITRATION=deepseek-chat
LLM_EMBEDDING=deepseek-embedding
SYSTEM_LANGUAGE=ru

OPENAI_API_KEY=
LLM_FALLBACK=gpt-4o-mini

LOCAL_AI_ENABLED=false

# === SECURITY ===
# Each value is 32-byte hex (64 chars). Generate via: openssl rand -hex 32
AGENT_API_KEYS={"agent_designer":"REPLACE_64_HEX_CHARS","agent_developer":"REPLACE_64_HEX_CHARS"}

MAX_PAYLOAD_SIZE=262144
RATE_LIMIT_PER_AGENT=100
MAX_PAYLOAD_DEPTH=10
MAX_PAYLOAD_KEYS=500

# === CURATOR ===
CURATOR_TEMPERATURE=0.1
MIN_EVENTS_FOR_DAILY=3
MIN_CONFIDENCE_FOR_L3=0.6
MIN_L2_REPETITIONS_FOR_L3=2
L4_FULL_SNAPSHOT_INTERVAL_WEEKS=4
L4_MIN_CHANGE_PERCENT=5
L3_STALENESS_DAYS=90
TOOL_UNUSED_DAYS=60

RETENTION_DAYS=14
DAILY_HOURS=24
WEEKLY_DAYS=7
