# ==================== ХРАНИЛИЩА ====================
DATABASE_URL=postgresql://cognitive:cognitive_secret@postgres:5432/cognitive_core
REDIS_URL=redis://redis:6379
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=l4-snapshots
S3_SECURE=false

# ==================== МОДЕЛЬНЫЙ РЕЕСТР ====================
# Внешний API (DeepSeek)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
LLM_DAILY_ANALYZER=deepseek-chat
LLM_WEEKLY_CONSOLIDATOR=deepseek-chat
LLM_CURATOR_FILTER=deepseek-chat
LLM_CURATOR_QUALITY=deepseek-chat
LLM_CURATOR_AUDIT=deepseek-chat
LLM_CURATOR_ARBITRATION=deepseek-chat
LLM_EMBEDDING=deepseek-embedding

# Fallback (OpenAI)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-key-here
LLM_FALLBACK=gpt-4o-mini

# A/B тестирование (любая функция; при LLM_AB_TRAFFIC_PERCENT>0 направляет % на B-модель)
LLM_DAILY_ANALYZER_B=
LLM_WEEKLY_CONSOLIDATOR_B=
LLM_CURATOR_FILTER_B=
LLM_CURATOR_QUALITY_B=
LLM_CURATOR_AUDIT_B=
LLM_CURATOR_ARBITRATION_B=
LLM_AB_TRAFFIC_PERCENT=0

# Локальный ИИ (Ollama, гибрид Local+Cloud)
# При LOCAL_AI_ENABLED=true можно ставить ollama:<model> в LLM_<function>
# Пример гибрида для RTX 3090 24GB (см. LOCAL_LLM.md):
#   LLM_DAILY_ANALYZER=ollama:deepseek-r1:14b   ← локально (часто, простая task)
#   LLM_WEEKLY_CONSOLIDATOR=deepseek-chat       ← cloud (редко, точность важна)
#   LLM_CURATOR_AUDIT=deepseek-chat             ← cloud (фильтрация качества)
LOCAL_AI_ENABLED=false
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CURATOR_MODEL=qwen3:14b
OLLAMA_FAST_MODEL=llama4:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# GPU acceleration для embeddings (требует Dockerfile.gpu + docker-compose.gpu.yml)
EMBEDDING_USE_GPU=false

# ==================== БЕЗОПАСНОСТЬ ====================
AGENT_API_KEYS={"agent_designer":"key-design-001","agent_developer":"key-dev-001"}
MAX_PAYLOAD_SIZE=262144
RATE_LIMIT_PER_AGENT=100
MAX_PAYLOAD_DEPTH=10
MAX_PAYLOAD_KEYS=500

# ==================== TLS (опционально) ====================
SSL_CERT_PATH=
SSL_KEY_PATH=

# ==================== КУРАТОР ====================
CURATOR_TEMPERATURE=0.1
MIN_EVENTS_FOR_DAILY=3
MIN_CONFIDENCE_FOR_L3=0.6
MIN_L2_REPETITIONS_FOR_L3=2
L4_FULL_SNAPSHOT_INTERVAL_WEEKS=4
L4_MIN_CHANGE_PERCENT=5
L3_STALENESS_DAYS=90
TOOL_UNUSED_DAYS=60

# ==================== ЦИКЛЫ ====================
RETENTION_DAYS=14
DAILY_HOURS=24
WEEKLY_DAYS=7
